parameters:
    level: 5
    paths:
        - src
        - tests
    excludePaths:
        - tests/TestCase.php
        # Pulse card extends an optional dependency (laravel/pulse) not installed in CI
        - src/Pulse/DefenderPulseCard.php
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        - '#Call to an undefined static method.*#'
        - '#Cannot call method.*on mixed#'
        - '#Method.*should return.*but returns mixed#'
        - '#Access to an undefined property.*#'
        - '#Unable to resolve the template type.*#'
        - '#Method.*has parameter.*with no type specified#'
        - '#Call to an undefined method.*Builder.*::forRole\(\)#'
        - '#Call to an undefined method.*Builder.*::forCategory\(\)#'
        - '#Unreachable statement - code above always terminates#'
        - '#Call to an undefined method Illuminate\\Contracts\\Auth\\Factory::(check|id)\(\)#'
        -
            identifier: missingType.iterableValue
        -
            identifier: missingType.generics
        # Optional dependency (livewire/livewire) may not be installed
        - '#Attribute class Livewire\\Attributes\\Lazy does not exist#'
        # PHPStan without Larastan cannot infer Eloquent query builder return types
        - '#Method Metalinked\\LaravelDefender\\Services\\BlocklistService::all\(\) should return#'
    bootstrapFiles:
        - vendor/autoload.php
